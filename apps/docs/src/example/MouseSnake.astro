---
export const title = "アニメーションDOM追従";
type Props = Omit<astroHTML.JSX.HtmlHTMLAttributes, "id">;
---

<div id="mouse-snake-box" {...Astro.props}>
  <div
    id="mouse-snake-pointer"
    style="width: 1rem; height: 1rem; background-color: cadetblue; margin-top: 0;"
  >
  </div>
</div>

<script>
  import {
    DefaultSimulatorService,
    DomPhysics,
    DomSource,
    DomVisualizer,
    Kinetics,
    MousePositionClock,
    SpringEngine,
    type VectorReadablePort,
  } from "@yyyoichi/chrono-kinesis";
  const simulation = new DefaultSimulatorService({ fixedStepSec: 1 / 20 });

  const box = document.getElementById("mouse-snake-box")!;
  const mouse = new MousePositionClock(box);
  const pointer = new DomSource(
    document.getElementById("mouse-snake-pointer")!,
  );

  const vis = new DomVisualizer();
  const engine = new SpringEngine({ settleMs: 400, zeta: 0.7 });
  simulation.add({
    clock: mouse,
    target: mouse,
    kinetics: new Kinetics(pointer.position(), { engine: engine }),
    physics: new DomPhysics(pointer, vis),
  });

  let target: VectorReadablePort = pointer;
  for (let i = 1; i <= 5; i++) {
    const clone = pointer.clone(
      {
        opacity: `${1 - 0.1 * i}`,
      },
      box,
    );
    const node = new Kinetics(clone.position(), {
      engine: engine.clone({ settleMs: 400 - i * 10 }),
    });
    simulation.add({
      clock: mouse,
      target: target,
      kinetics: node,
      physics: new DomPhysics(clone, vis),
    });
    target = node;
  }
  simulation.run();
</script>
